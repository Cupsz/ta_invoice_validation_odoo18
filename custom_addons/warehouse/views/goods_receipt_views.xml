<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="warehouse_gr_form" model="ir.ui.view">
        <field name="name">warehouse.gr.form</field>
        <field name="model">stock.picking</field>
        <field name="arch" type="xml">
            <form string="Goods Receipt">
                <header>
                    <button name="button_validate_gr" string="Validate Receipt"
                            type="object" class="btn-primary"
                            invisible="state in ['done','cancel']"
                            confirm="Konfirmasi penerimaan barang?"/>
                    <button name="action_print_goods_receipt" string="🖨 Print GR"
                            type="object" class="btn-secondary"
                            invisible="state != 'done'"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,assigned,done"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                        <h4 class="text-muted">GR: <field name="gr_number" readonly="1" nolabel="1"/></h4>
                    </div>
                    <group>
                        <group string="Purchase Order">
                            <field name="origin" string="PO Number" readonly="1"/>
                            <field name="partner_id" string="Vendor" readonly="1"/>
                        </group>
                        <group string="Penerimaan">
                            <field name="gr_receive_date" string="Receive Date"/>
                            <field name="gr_condition" string="Condition"/>
                        </group>
                    </group>
                    <group string="Notes">
                        <field name="gr_notes" nolabel="1" placeholder="Catatan penerimaan..."/>
                    </group>
                    <notebook>
                        <page string="Detail Barang">
                            <field name="move_ids" readonly="state == 'done'">
                                <list editable="bottom">
                                    <field name="product_id" string="Product" readonly="1"/>
                                    <field name="product_uom_qty" string="Qty Ordered" readonly="1"/>
                                    <field name="quantity" string="Qty Received"/>
                                    <field name="product_uom" string="Unit" readonly="1"/>
                                    <field name="state" column_invisible="1"/>
                                    <field name="picking_id" column_invisible="1"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="warehouse_gr_tree" model="ir.ui.view">
        <field name="name">warehouse.gr.tree</field>
        <field name="model">stock.picking</field>
        <field name="arch" type="xml">
            <list string="Goods Receipts"
                  decoration-info="state == 'assigned'"
                  decoration-success="state == 'done'">
                <field name="name" string="Nomor"/>
                <field name="origin" string="Purchase Order"/>
                <field name="partner_id" string="Vendor"/>
                <field name="gr_receive_date" string="Receive Date"/>
                <field name="gr_condition" string="Condition"/>
                <field name="state" widget="badge"
                       decoration-info="state == 'assigned'"
                       decoration-success="state == 'done'"
                       decoration-danger="state == 'cancel'"/>
            </list>
        </field>
    </record>

    <record id="warehouse_gr_action" model="ir.actions.act_window">
        <field name="name">Goods Receipts</field>
        <field name="res_model">stock.picking</field>
        <field name="view_mode">list,form</field>
        <field name="view_ids" eval="[
            (5,0,0),
            (0,0,{'view_mode':'list','view_id':ref('warehouse_gr_tree')}),
            (0,0,{'view_mode':'form','view_id':ref('warehouse_gr_form')}),
        ]"/>
        <field name="domain">[('picking_type_code','=','incoming')]</field>
        <field name="context">{'search_default_assigned': 1}</field>
    </record>

</odoo>
