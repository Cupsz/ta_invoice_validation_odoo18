<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!--
        Form sederhana untuk membuat Vendor baru langsung dari layar
        Purchase Order ("Create and Edit..." pada field Vendor).
        Sengaja hanya menampilkan field yang benar-benar penting untuk
        proses procurement, supaya user tidak dihadapkan pada form
        res.partner lengkap (tab Contacts & Addresses, Sales & Purchase,
        Invoicing, Internal Notes, dsb).
    -->
    <record id="procurement_res_partner_quick_form" model="ir.ui.view">
        <field name="name">procurement.res.partner.quick.form</field>
        <field name="model">res.partner</field>
        <field name="priority">99</field>
        <field name="arch" type="xml">
            <form string="Buat Vendor Baru">
                <!-- vendor procurement selalu berupa badan usaha (PT/CV/dst) -->
                <field name="company_type" invisible="1"/>
                <field name="is_company" invisible="1" force_save="1"/>

                <sheet>
                    <div class="oe_title">
                        <label for="name" string="Nama Vendor"/>
                        <h1>
                            <field name="name" placeholder="e.g. PT Cahaya Matahari" required="1"/>
                        </h1>
                    </div>

                    <group>
                        <group string="Kontak">
                            <field name="phone" string="Telepon"/>
                            <field name="email" string="Email"/>
                        </group>
                        <group string="Data Pajak &amp; Alamat">
                            <field name="vat" string="NPWP" placeholder="00.000.000.0-000.000"/>
                            <field name="street" string="Alamat"/>
                            <field name="city" string="Kota"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

</odoo>
