<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="module_category_invoice_validation" model="ir.module.category">
            <field name="name">Invoice Validation TA</field>
            <field name="sequence">30</field>
        </record>
        <record id="group_invoice_validation_user" model="res.groups">
            <field name="name">Tim Finance</field>
            <field name="category_id" ref="module_category_invoice_validation"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>
        <record id="group_invoice_validation_manager" model="res.groups">
            <field name="name">Finance Manager</field>
            <field name="category_id" ref="module_category_invoice_validation"/>
            <field name="implied_ids" eval="[(4, ref('group_invoice_validation_user'))]"/>
            <field name="users" eval="[(4, ref('base.user_admin'))]"/>
        </record>
    </data>
</odoo>
